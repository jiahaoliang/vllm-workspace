+std::vector<int> RealClient::batch_get_start(
+    const std::vector<std::string> &keys) {
+    std::vector<int> results(
+        keys.size(), static_cast<int>(toInt(ErrorCode::INVALID_PARAMS)));
+    if (!client_) {
+        LOG(ERROR) << "Client is not initialized";
+        return results;
+    }
+    if (keys.empty()) {
+        return {};
+    }
+
+    // Master interaction only here: query replicas + lease.
+    const auto query_results = client_->BatchQuery(keys);
+    auto local_endpoints = client_->GetLocalEndpoints();
+
+    std::lock_guard<std::mutex> lock(session_mutex_);
+    for (size_t i = 0; i < keys.size(); ++i) {
+        if (!query_results[i]) {
+            results[i] = static_cast<int>(toInt(query_results[i].error()));
+            get_sessions_.erase(keys[i]);
+            continue;
+        }
+
+        auto query_result = query_results[i].value();
+        if (query_result.IsLeaseExpired()) {
+            results[i] = static_cast<int>(toInt(ErrorCode::LEASE_EXPIRED));
+            get_sessions_.erase(keys[i]);
+            continue;
+        }
+
+        const auto *replica =
+            SelectCompleteMemoryReplica(query_result.replicas, local_endpoints);
+        if (!replica) {
+            LOG(ERROR) << "No complete memory replica for key: " << keys[i];
+            results[i] = static_cast<int>(toInt(ErrorCode::INVALID_REPLICA));
+            get_sessions_.erase(keys[i]);
+            continue;
+        }
+
+        get_sessions_[keys[i]] = GetSessionEntry{
+            .replica = *replica,
+            .lease_deadline = query_result.lease_timeout,
+        };
+        results[i] = 0;
+    }
+    return results;
+}
+
+std::vector<int> RealClient::batch_get_into_multi_buffer_ranges(
+    const std::vector<std::string> &keys,
+    const std::vector<std::vector<void *>> &all_buffers,
+    const std::vector<std::vector<size_t>> &all_sizes,
+    const std::vector<std::vector<size_t>> &all_src_offsets) {
+    std::vector<int> results(
+        keys.size(), static_cast<int>(toInt(ErrorCode::INVALID_PARAMS)));
+    if (!client_ || keys.size() != all_buffers.size() ||
+        keys.size() != all_sizes.size() ||
+        keys.size() != all_src_offsets.size()) {
+        LOG(ERROR) << "Invalid get ranges args";
+        return results;
+    }
+    if (!client_->transfer_submitter_) {
+        LOG(ERROR) << "TransferSubmitter not initialized";
+        return results;
+    }
+
+    // No Master RPC here: use cached replica + lease_deadline from start.
+    std::vector<std::tuple<size_t, TransferFuture>> pending_transfers;
+    std::vector<std::chrono::steady_clock::time_point> lease_deadlines(
+        keys.size());
+
+    {
+        std::lock_guard<std::mutex> lock(session_mutex_);
+        const auto now = std::chrono::steady_clock::now();
+        for (size_t i = 0; i < keys.size(); ++i) {
+            const auto &buffers = all_buffers[i];
+            const auto &sizes = all_sizes[i];
+            const auto &src_offsets = all_src_offsets[i];
+            if (buffers.size() != sizes.size() ||
+                buffers.size() != src_offsets.size()) {
+                continue;
+            }
+            auto it = get_sessions_.find(keys[i]);
+            if (it == get_sessions_.end()) {
+                continue;
+            }
+            if (now >= it->second.lease_deadline) {
+                get_sessions_.erase(it);
+                results[i] = static_cast<int>(toInt(ErrorCode::LEASE_EXPIRED));
+                continue;
+            }
+
+            lease_deadlines[i] = it->second.lease_deadline;
+            const auto &replica = it->second.replica;
+            int64_t transferred = 0;
+            bool submit_failed = false;
+            for (size_t j = 0; j < buffers.size(); ++j) {
+                std::vector<Slice> slices{Slice{buffers[j], sizes[j]}};
+                auto future = client_->transfer_submitter_->submitRangeRead(
+                    replica, slices, src_offsets[j]);
+                if (!future) {
+                    LOG(ERROR)
+                        << "Failed to submit range read for key: " << keys[i];
+                    results[i] =
+                        static_cast<int>(toInt(ErrorCode::TRANSFER_FAIL));
+                    submit_failed = true;
+                    break;
+                }
+                pending_transfers.emplace_back(i, std::move(*future));
+                transferred += static_cast<int64_t>(sizes[j]);
+            }
+            if (!submit_failed) {
+                results[i] = static_cast<int>(transferred);
+            }
+        }
+    }
+
+    for (auto &[index, future] : pending_transfers) {
+        if (results[index] < 0) {
+            (void)future.get();
+            continue;
+        }
+        ErrorCode err = future.get();
+        if (err != ErrorCode::OK) {
+            LOG(ERROR) << "Range read failed for key: " << keys[index]
+                       << " with error: " << static_cast<int>(err);
+            results[index] = static_cast<int>(toInt(err));
+        } else if (std::chrono::steady_clock::now() >= lease_deadlines[index]) {
+            results[index] = static_cast<int>(toInt(ErrorCode::LEASE_EXPIRED));
+        }
+    }
+
+    // Drop sessions that hit LEASE_EXPIRED (pre-submit or post-wait).
+    {
+        std::lock_guard<std::mutex> lock(session_mutex_);
+        const int lease_expired = static_cast<int>(toInt(ErrorCode::LEASE_EXPIRED));
+        for (size_t i = 0; i < keys.size(); ++i) {
+            if (results[i] == lease_expired) {
+                get_sessions_.erase(keys[i]);
+            }
+        }
+    }
+    return results;
+}
+
+int RealClient::batch_get_end(const std::vector<std::string> &keys) {
+    std::lock_guard<std::mutex> lock(session_mutex_);
+    for (const auto &key : keys) {
+        get_sessions_.erase(key);
+    }
+    return 0;
+}
+
+std::vector<int> RealClient::batch_put_start(
+    const std::vector<std::string> &keys, const std::vector<size_t> &sizes,
+    const ReplicateConfig &config) {
+    std::vector<int> results(keys.size(), 0);
+    if (!client_ || keys.size() != sizes.size()) {
+        LOG(ERROR) << "Invalid batch_put_start args";
+        return std::vector<int>(
+            keys.size(), static_cast<int>(toInt(ErrorCode::INVALID_PARAMS)));
+    }
+
+    std::vector<std::string> start_keys;
+    std::vector<uint64_t> start_sizes;
+    std::vector<size_t> start_indices;
+    {
+        std::lock_guard<std::mutex> lock(session_mutex_);
+        for (size_t i = 0; i < keys.size(); ++i) {
+            if (put_sessions_.count(keys[i]) != 0) {
+                LOG(ERROR) << "Put session already exists for key: " << keys[i];
+                results[i] = static_cast<int>(toInt(ErrorCode::INVALID_PARAMS));
+                continue;
+            }
+            start_keys.push_back(keys[i]);
+            start_sizes.push_back(static_cast<uint64_t>(sizes[i]));
+            start_indices.push_back(i);
+        }
+    }
+    if (start_keys.empty()) {
+        return results;
+    }
+
+    // Same first half as Client::BatchPut (StartBatchPut → master
+    // BatchPutStart).
+    auto start_responses =
+        client_->StartBatchPutForSizes(start_keys, start_sizes, config);
+    std::lock_guard<std::mutex> lock(session_mutex_);
+    for (size_t j = 0; j < start_keys.size(); ++j) {
+        const size_t i = start_indices[j];
+        if (!start_responses[j]) {
+            results[i] = static_cast<int>(toInt(start_responses[j].error()));
+            continue;
+        }
+        auto replicas = std::move(start_responses[j].value());
+        if (!HasMemoryReplica(replicas)) {
+            if (client_->hot_cache_) {
+                client_->hot_cache_->RemoveHotKeys({keys[i]});
+            }
+            (void)client_->master_client_.BatchPutRevoke({keys[i]});
+            results[i] = static_cast<int>(toInt(ErrorCode::INVALID_REPLICA));
+            continue;
+        }
+        put_sessions_[keys[i]] = PutSessionEntry{
+            .replicas = std::move(replicas),
+            .object_size = static_cast<uint64_t>(sizes[i]),
+        };
+    }
+    return results;
+}
+
+std::vector<int> RealClient::batch_put_from_multi_buffer_ranges(
+    const std::vector<std::string> &keys,
+    const std::vector<std::vector<void *>> &all_buffers,
+    const std::vector<std::vector<size_t>> &all_sizes,
+    const std::vector<std::vector<size_t>> &all_dst_offsets) {
+    std::vector<int> results(
+        keys.size(), static_cast<int>(toInt(ErrorCode::INVALID_PARAMS)));
+    if (!client_ || keys.size() != all_buffers.size() ||
+        keys.size() != all_sizes.size() ||
+        keys.size() != all_dst_offsets.size()) {
+        LOG(ERROR) << "Invalid put ranges args";
+        return results;
+    }
+    if (!client_->transfer_submitter_) {
+        LOG(ERROR) << "TransferSubmitter not initialized";
+        return results;
+    }
+
+    // Same pattern as Client::SubmitTransfers: submit per key/replica, then
+    // wait.
+    std::vector<std::tuple<size_t, TransferFuture>> pending_transfers;
+
+    {
+        std::lock_guard<std::mutex> lock(session_mutex_);
+        for (size_t i = 0; i < keys.size(); ++i) {
+            const auto &buffers = all_buffers[i];
+            const auto &sizes = all_sizes[i];
+            const auto &dst_offsets = all_dst_offsets[i];
+            if (buffers.size() != sizes.size() ||
+                buffers.size() != dst_offsets.size()) {
+                continue;
+            }
+            auto it = put_sessions_.find(keys[i]);
+            if (it == put_sessions_.end()) {
+                continue;
+            }
+
+            bool overflow = false;
+            int64_t transferred = 0;
+            for (size_t j = 0; j < buffers.size(); ++j) {
+                if (dst_offsets[j] > it->second.object_size ||
+                    sizes[j] > it->second.object_size - dst_offsets[j]) {
+                    overflow = true;
+                    break;
+                }
+                transferred += static_cast<int64_t>(sizes[j]);
+            }
+            if (overflow) {
+                continue;
+            }
+
+            bool submitted = false;
+            bool submit_failed = false;
+            for (const auto &replica : it->second.replicas) {
+                if (!replica.is_memory_replica()) {
+                    continue;
+                }
+                for (size_t j = 0; j < buffers.size(); ++j) {
+                    std::vector<Slice> slices{Slice{buffers[j], sizes[j]}};
+                    auto future =
+                        client_->transfer_submitter_->submitRangeWrite(
+                            replica, slices, dst_offsets[j]);
+                    if (!future) {
+                        LOG(ERROR) << "Failed to submit range write for key: "
+                                   << keys[i];
+                        results[i] =
+                            static_cast<int>(toInt(ErrorCode::TRANSFER_FAIL));
+                        submit_failed = true;
+                        break;
+                    }
+                    pending_transfers.emplace_back(i, std::move(*future));
+                    submitted = true;
+                }
+                if (submit_failed) {
+                    break;
+                }
+            }
+            if (submit_failed) {
+                continue;
+            }
+            if (!submitted) {
+                results[i] =
+                    static_cast<int>(toInt(ErrorCode::INVALID_REPLICA));
+                continue;
+            }
+            results[i] = static_cast<int>(transferred);
+        }
+    }
+
+    for (auto &[index, future] : pending_transfers) {
+        if (results[index] < 0) {
+            (void)future.get();
+            continue;
+        }
+        ErrorCode err = future.get();
+        if (err != ErrorCode::OK) {
+            LOG(ERROR) << "Range write failed for key: " << keys[index]
+                       << " with error: " << static_cast<int>(err);
+            results[index] = static_cast<int>(toInt(err));
+        }
+    }
+    return results;
+}
+
+std::vector<int> RealClient::batch_put_end(
+    const std::vector<std::string> &keys) {
+    std::vector<int> results(
+        keys.size(), static_cast<int>(toInt(ErrorCode::INVALID_PARAMS)));
+    if (!client_) {
+        LOG(ERROR) << "Client is not initialized";
+        return results;
+    }
+
+    std::vector<std::string> end_keys;
+    std::vector<size_t> end_indices;
+    {
+        std::lock_guard<std::mutex> lock(session_mutex_);
+        for (size_t i = 0; i < keys.size(); ++i) {
+            if (put_sessions_.count(keys[i]) == 0) {
+                results[i] = static_cast<int>(toInt(ErrorCode::INVALID_PARAMS));
+                continue;
+            }
+            end_keys.push_back(keys[i]);
+            end_indices.push_back(i);
+        }
+    }
+    if (end_keys.empty()) {
+        return results;
+    }
 
+    // Same RPC FinalizeBatchPut uses after successful transfers.
+    auto end_responses = client_->master_client_.BatchPutEnd(end_keys);
+    std::lock_guard<std::mutex> lock(session_mutex_);
+    for (size_t j = 0; j < end_keys.size(); ++j) {
+        const size_t i = end_indices[j];
+        put_sessions_.erase(end_keys[j]);
+        if (!end_responses[j]) {
+            results[i] = static_cast<int>(toInt(end_responses[j].error()));
+        } else {
+            results[i] = 0;
+        }
+    }
+    return results;
+}
+
+std::vector<int> RealClient::batch_put_revoke(
+    const std::vector<std::string> &keys) {
+    std::vector<int> results(
+        keys.size(), static_cast<int>(toInt(ErrorCode::INVALID_PARAMS)));
+    if (!client_) {
+        LOG(ERROR) << "Client is not initialized";
+        return results;
+    }
+
+    std::vector<std::string> revoke_keys;
+    std::vector<size_t> revoke_indices;
+    {
+        std::lock_guard<std::mutex> lock(session_mutex_);
+        for (size_t i = 0; i < keys.size(); ++i) {
+            if (put_sessions_.count(keys[i]) == 0) {
+                results[i] = static_cast<int>(toInt(ErrorCode::INVALID_PARAMS));
+                continue;
+            }
+            revoke_keys.push_back(keys[i]);
+            revoke_indices.push_back(i);
+        }
+    }
+    if (revoke_keys.empty()) {
+        return results;
+    }
+
+    // Same path FinalizeBatchPut uses on transfer failure.
+    if (client_->hot_cache_ && !revoke_keys.empty()) {
+        client_->hot_cache_->RemoveHotKeys(revoke_keys);
+    }
+    auto revoke_responses = client_->master_client_.BatchPutRevoke(revoke_keys);
+    std::lock_guard<std::mutex> lock(session_mutex_);
+    for (size_t j = 0; j < revoke_keys.size(); ++j) {
+        const size_t i = revoke_indices[j];
+        put_sessions_.erase(revoke_keys[j]);
+        if (!revoke_responses[j]) {
+            results[i] = static_cast<int>(toInt(revoke_responses[j].error()));
+        } else {
+            results[i] = 0;
+        }
+    }
     return results;
 }
 
